datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Quest {
  id          String    @id @default(uuid())
  titulo      String
  descricao   String?
  xp          Int       @default(0)
  concluida   Boolean   @default(false)
  criadoEm    DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
  deletadoEm  DateTime?

  @@map("quests")
}